{
  "name": "snd-platform",
  "private": true,
  "workspaces": ["apps/mobile", "apps/snd-web", "apps/snd-api"],
  "scripts": {
    "mobile": "npm run start --workspace=apps/mobile",
    "web": "npm run dev --workspace=apps/snd-web",
    "api": "npm run dev --workspace=apps/snd-api",
    "mvp": "concurrently -n api,web -c blue,magenta \"npm run api\" \"npm run web\"",
    "serve:static": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/serve-static.ps1"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  },
  "engines": { "node": ">=20" }
}
